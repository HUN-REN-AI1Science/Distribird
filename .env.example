# LitoPri configuration
# Copy to .env and fill in your values:  cp .env.example .env

# Auth (change these!)
LITOPRI_AUTH_USERNAME=demo
LITOPRI_AUTH_PASSWORD=changeme

# LLM (required — any OpenAI-compatible endpoint via LiteLLM)
LITOPRI_LLM_BASE_URL=https://your-llm-host.example.com/api
LITOPRI_LLM_API_KEY=sk-your-key-here
LITOPRI_LLM_MODEL=gemini-3-pro

# Semantic Scholar (optional, increases rate limits)
LITOPRI_SEMANTIC_SCHOLAR_API_KEY=

# Deep Research (optional)
LITOPRI_DEEP_RESEARCH_BASE_URL=
LITOPRI_DEEP_RESEARCH_API_KEY=
LITOPRI_DEEP_RESEARCH_MODEL=o4-mini-deep-research
