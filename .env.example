# Distribird configuration
# Copy to .env and fill in your values:  cp .env.example .env

# Auth (change these!)
DISTRIBIRD_AUTH_USERNAME=demo
DISTRIBIRD_AUTH_PASSWORD=changeme

# LLM (required — any OpenAI-compatible endpoint via LiteLLM)
DISTRIBIRD_LLM_BASE_URL=https://your-llm-host.example.com/api
DISTRIBIRD_LLM_API_KEY=sk-your-key-here
DISTRIBIRD_LLM_MODEL=gemini-3-pro

# Full-paper reading ("page-turning"). Extraction reads the WHOLE paper, not just
# the first ~30k characters. A paper that fits the model's context window is read
# in one call; a longer one is split into overlapping chunks ("pages"), each read
# separately, then the extracted values are merged. Set the context window of YOUR
# model so the chunk size is computed correctly — too high overflows the window,
# too low wastes calls. Lower it for a small local model and paging kicks in.
DISTRIBIRD_LLM_MAX_CONTEXT_TOKENS=255000
# Tokens reserved for the model's answer (and reasoning) when sizing each page.
DISTRIBIRD_LLM_RESERVED_ANSWER_TOKENS=4000
# Chars-per-token estimate used to convert the token budget to characters
# (no tokenizer is bundled). 3.5 under-fills so dense numeric text won't overflow.
DISTRIBIRD_LLM_CHARS_PER_TOKEN=3.5
# Safety cap on pages per paper. If a paper needs more, the Methods/Results pages
# are kept first and a warning is logged — raise this (or the context window) to
# read everything.
DISTRIBIRD_EXTRACTION_MAX_CHUNKS=8
# Overlap between consecutive pages so a value on a page boundary isn't lost.
DISTRIBIRD_EXTRACTION_CHUNK_OVERLAP_CHARS=1500
# Hard cap on stored full text per paper at fetch time (memory guard; the old
# behaviour truncated to 30000). The per-call page size above governs reading.
DISTRIBIRD_FULLTEXT_STORAGE_MAX_CHARS=400000

# Semantic Scholar (optional, increases rate limits)
DISTRIBIRD_SEMANTIC_SCHOLAR_API_KEY=

# Deep Research (optional)
DISTRIBIRD_DEEP_RESEARCH_BASE_URL=
DISTRIBIRD_DEEP_RESEARCH_API_KEY=
DISTRIBIRD_DEEP_RESEARCH_MODEL=o4-mini-deep-research

# Contact email for OpenAlex and Unpaywall. Set a real address to enable the
# open-access mirror fallback below (Unpaywall requires it).
DISTRIBIRD_OPENALEX_EMAIL=

# PDF full-text fallbacks, tried when a paper's PDF URL is blocked (e.g. 403).
# Tier B (on by default): resolve open-access copies via Unpaywall. Pure HTTP,
#   needs DISTRIBIRD_OPENALEX_EMAIL set.
DISTRIBIRD_ENABLE_OA_MIRROR_FALLBACK=true
# Tier C (off by default): headless stealth browser for JavaScript bot walls.
#   Needs the stealth extra: pip install "distribird[stealth]" && python -m camoufox fetch
#   Does not run on Streamlit Community Cloud; it is skipped there.
DISTRIBIRD_ENABLE_STEALTH_FETCH=false
DISTRIBIRD_STEALTH_FETCH_TIMEOUT=90.0
# When a PDF URL serves HTML instead of a PDF, extract the article text from the
# HTML (e.g. PubMed Central full-text pages). A quality gate rejects bot-challenge
# pages and thin abstract-only pages. On by default.
DISTRIBIRD_ENABLE_HTML_FULLTEXT=true
DISTRIBIRD_HTML_FULLTEXT_MIN_CHARS=2000
